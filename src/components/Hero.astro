---
/**
 * Herbruikbare hero met sterke belofte + primaire CTA (offerte) en secundaire
 * CTA (bellen). Boven de vouw op home én dienstpagina's — conversiegericht.
 * Optionele afbeelding wordt geoptimaliseerd via astro:assets (eager = LCP).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { site } from '@data/site';
import Icon from '@components/Icon.astro';

interface Props {
  title: string; // wordt als H1 gerenderd
  subtitle: string;
  eyebrow?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  /** Korte vertrouwens-chips onder de CTA's */
  badges?: string[];
  primaryLabel?: string;
  primaryHref?: string;
}

const {
  title,
  subtitle,
  eyebrow,
  image,
  imageAlt = '',
  badges = ['Vrijblijvende offerte', 'Eén aanspreekpunt', `${site.stats.projects} projecten`],
  primaryLabel = 'Vraag vrijblijvend een offerte aan',
  primaryHref = '/contact/',
} = Astro.props;

const hasImage = Boolean(image);
---
<section class="relative overflow-hidden bg-gradient-to-b from-brand-50 to-sand">
  <!-- subtiele decoratie -->
  <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-100/60 blur-3xl" aria-hidden="true"></div>

  <div class:list={['container-px relative grid items-center gap-10 py-14 lg:py-20', hasImage ? 'lg:grid-cols-2' : 'max-w-3xl text-center']}>
    <div>
      {eyebrow && (
        <p class="mb-3 inline-flex items-center gap-2 rounded-full bg-white px-3 py-1 text-xs font-bold uppercase tracking-wider text-brand-700 ring-1 ring-brand-100">
          <Icon name="map-pin" class="h-3.5 w-3.5" /> {eyebrow}
        </p>
      )}
      <h1 class="text-4xl font-extrabold leading-[1.08] tracking-tight text-ink sm:text-5xl">
        {title}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-stone-700">{subtitle}</p>

      <div class:list={['mt-8 flex flex-col gap-3 sm:flex-row', hasImage ? '' : 'sm:justify-center']}>
        <a href={primaryHref} class="btn-primary btn-lg">
          {primaryLabel}
          <Icon name="arrow-right" class="h-5 w-5" />
        </a>
        <a href={site.phone.href} class="btn-secondary btn-lg">
          <Icon name="phone" class="h-5 w-5 text-brand-700" />
          Bel {site.phone.display}
        </a>
      </div>

      {badges.length > 0 && (
        <ul class:list={['mt-7 flex flex-wrap gap-x-5 gap-y-2 text-sm font-medium text-stone-700', hasImage ? '' : 'justify-center']}>
          {badges.map((b) => (
            <li class="flex items-center gap-1.5">
              <Icon name="check" class="h-4 w-4 text-success" /> {b}
            </li>
          ))}
        </ul>
      )}
    </div>

    {hasImage && (
      <div class="relative">
        <Image
          src={image!}
          alt={imageAlt}
          widths={[480, 768, 1024]}
          sizes="(min-width: 1024px) 50vw, 100vw"
          loading="eager"
          fetchpriority="high"
          class="aspect-[4/3] w-full rounded-2xl object-cover shadow-xl ring-1 ring-stone-200"
        />
        <!-- Garantie-badge over de foto -->
        <div class="absolute -bottom-4 -left-4 hidden items-center gap-2 rounded-xl bg-white px-4 py-3 shadow-lg ring-1 ring-stone-200 sm:flex">
          <Icon name="shield" class="h-7 w-7 text-success" />
          <span class="text-sm font-bold leading-tight text-ink">Garantie<br />op ons werk</span>
        </div>
      </div>
    )}
  </div>
</section>
