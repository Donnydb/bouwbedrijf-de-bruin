---
/**
 * Hero — licht, typografie-gedreven en (bijna) monochroom (stijl rumlingbouw.nl).
 * Grote, vette Archivo-kop met een sterke belofte + primaire CTA (offerte) en
 * secundaire CTA (bellen). Optionele afbeelding wordt strak ingekaderd (geen
 * fotodominante overlay).
 *
 * Voor een kop met accent-woorden ("uw vertrouwde **aannemer**") geef je een
 * `slot="title"` mee; anders wordt de platte `title`-prop gebruikt.
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { site } from '@data/site';
import Icon from '@components/Icon.astro';

interface Props {
  title: string; // wordt als H1 gerenderd (of via slot="title")
  subtitle: string;
  eyebrow?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  /** Korte vertrouwens-chips onder de CTA's */
  badges?: string[];
  primaryLabel?: string;
  primaryHref?: string;
}

const {
  title,
  subtitle,
  eyebrow,
  image,
  imageAlt = '',
  badges = ['Vrijblijvende offerte', 'Eén aanspreekpunt', `${site.stats.projects} projecten`],
  primaryLabel = 'Vraag vrijblijvend een offerte aan',
  primaryHref = '/contact/',
} = Astro.props;

const hasImage = Boolean(image);
---
<section class="relative border-b border-stone-200 bg-white">
  <div class:list={['container-px relative grid items-center gap-12 py-16 lg:py-24', hasImage ? 'lg:grid-cols-[1.1fr_0.9fr]' : 'max-w-3xl']}>
    <div>
      {eyebrow && (
        <p class="eyebrow mb-5">
          <Icon name="map-pin" class="h-3.5 w-3.5" /> {eyebrow}
        </p>
      )}
      <h1 class="text-4xl font-extrabold leading-[1.04] tracking-tight text-ink sm:text-5xl lg:text-6xl">
        <slot name="title">{title}</slot>
      </h1>
      <p class="mt-6 max-w-xl text-lg leading-relaxed text-stone-600">{subtitle}</p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a href={primaryHref} class="btn-primary btn-lg">
          {primaryLabel}
          <Icon name="arrow-right" class="h-5 w-5" />
        </a>
        <a href={site.phone.href} class="btn-secondary btn-lg">
          <Icon name="phone" class="h-5 w-5" />
          Bel {site.phone.display}
        </a>
      </div>

      {badges.length > 0 && (
        <ul class="mt-9 flex flex-wrap gap-x-6 gap-y-2 border-t border-stone-200 pt-6 text-sm font-medium text-stone-700">
          {badges.map((b) => (
            <li class="flex items-center gap-1.5">
              <Icon name="check" class="h-4 w-4 text-ink" /> {b}
            </li>
          ))}
        </ul>
      )}
    </div>

    {hasImage && (
      <div class="relative">
        <Image
          src={image!}
          alt={imageAlt}
          widths={[480, 768, 1024]}
          sizes="(min-width: 1024px) 45vw, 100vw"
          loading="eager"
          fetchpriority="high"
          class="aspect-[4/3] w-full rounded-lg object-cover ring-1 ring-stone-200"
        />
      </div>
    )}
  </div>
</section>
