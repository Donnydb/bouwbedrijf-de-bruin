---
/**
 * Sticky header met hoofdnavigatie, diensten-dropdown, klikbaar telefoonnummer
 * en primaire offerte-CTA. Mobiel menu via een klein, toegankelijk JS-toggle
 * (aria-expanded, sluit op Escape).
 */
import { site } from '@data/site';
import { services, serviceHref, isExternalService } from '@data/services';
import Icon from '@components/Icon.astro';
import { Image } from 'astro:assets';
import { img } from '@lib/images';

const nav = [
  { label: 'Home', href: '/' },
  { label: 'Diensten', href: '/diensten/' },
  { label: 'Over ons', href: '/over-ons/' },
  { label: 'Veelgestelde vragen', shortLabel: 'FAQ', href: '/faq/' },
  { label: 'Contact', href: '/contact/' },
];

// Markeer de actieve pagina op basis van het huidige pad.
const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---
<!-- Dunne donkere utility-balk (contact + werkgebied) — scrollt mee weg -->
<div class="bg-ink text-stone-300">
  <div class="container-px flex h-9 items-center justify-between gap-4 text-xs">
    <p class="hidden items-center gap-2 sm:flex">
      <Icon name="map-pin" class="h-3.5 w-3.5 text-stone-400" />
      Aannemer in {site.serviceAreaLabel}
    </p>
    <div class="flex items-center gap-4">
      <a href={site.phone.href} class="flex items-center gap-1.5 font-medium text-white hover:text-stone-300">
        <Icon name="phone" class="h-3.5 w-3.5" /> {site.phone.display}
      </a>
      <a href={`mailto:${site.email}`} class="hidden items-center gap-1.5 hover:text-white sm:flex">
        <Icon name="mail" class="h-3.5 w-3.5" /> {site.email}
      </a>
    </div>
  </div>
</div>

<header class="sticky top-0 z-50 border-b border-stone-200 bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/80">
  <div class="container-px flex h-16 items-center justify-between gap-4 lg:h-20">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 font-bold text-ink" aria-label={`${site.name} — naar de homepage`}>
      <Image src={img('logo-mark')} alt="" densities={[1.5, 2]} class="h-9 w-auto shrink-0" />
      <span class="leading-tight">
        <span class="block text-base font-extrabold tracking-tight">Bouwbedrijf</span>
        <span class="-mt-1 block text-xs font-semibold uppercase tracking-[0.18em] text-brand-700">De Bruin</span>
      </span>
    </a>

    <!-- Desktop-navigatie -->
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Hoofdnavigatie">
      {
        nav.map((item) =>
          item.href === '/diensten/' ? (
            <div class="group relative">
              <a
                href={item.href}
                aria-current={isActive(item.href) ? 'page' : undefined}
                class:list={[
                  'inline-flex items-center gap-1 rounded-lg px-3 py-2 text-sm font-semibold transition-colors hover:bg-stone-100',
                  isActive(item.href) ? 'text-brand-700' : 'text-stone-700',
                ]}
              >
                {item.label}
                <Icon name="chevron-down" class="h-4 w-4 transition-transform group-hover:rotate-180 group-focus-within:rotate-180" />
              </a>
              <!-- Dropdown: zichtbaar bij hover én toetsenbordfocus -->
              <div class="invisible absolute left-0 top-full w-64 translate-y-1 pt-2 opacity-0 transition-all group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100">
                <ul class="rounded-xl border border-stone-200 bg-white p-2 shadow-lg">
                  {services.map((s) => (
                    <li>
                      <a
                        href={serviceHref(s)}
                        target={isExternalService(s) ? '_blank' : undefined}
                        rel={isExternalService(s) ? 'noopener' : undefined}
                        class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-stone-700 hover:bg-brand-50 hover:text-brand-800"
                      >
                        <Icon name={s.icon} class="h-4 w-4 text-brand-600" />
                        <span class="flex-1">{s.navLabel}</span>
                        {isExternalService(s) && <Icon name="external-link" class="h-3.5 w-3.5 text-stone-400" title="Opent een aparte website" />}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'rounded-lg px-3 py-2 text-sm font-semibold transition-colors hover:bg-stone-100',
                isActive(item.href) ? 'text-brand-700' : 'text-stone-700',
              ]}
            >
              {item.label}
            </a>
          ),
        )
      }
    </nav>

    <!-- Rechts: telefoon + CTA (desktop) -->
    <div class="hidden items-center gap-3 lg:flex">
      <a href={site.phone.href} class="inline-flex items-center gap-2 text-sm font-semibold text-ink hover:text-brand-700">
        <Icon name="phone" class="h-4 w-4 text-brand-600" />
        {site.phone.display}
      </a>
      <a href="/contact/" class="btn-primary">Offerte aanvragen</a>
    </div>

    <!-- Mobiele knoppen -->
    <div class="flex items-center gap-2 lg:hidden">
      <a href={site.phone.href} class="btn-secondary !px-3 !py-2.5" aria-label={`Bel ${site.name}: ${site.phone.display}`}>
        <Icon name="phone" class="h-5 w-5 text-brand-700" />
      </a>
      <button
        type="button"
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-lg p-2.5 text-ink ring-1 ring-stone-300 hover:bg-stone-100"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Menu openen"
      >
        <Icon name="menu" class="h-6 w-6" id="menu-icon-open" />
        <Icon name="close" class="hidden h-6 w-6" id="menu-icon-close" />
      </button>
    </div>
  </div>

  <!-- Mobiel menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-stone-200 bg-sand lg:hidden"
    aria-label="Mobiele navigatie"
  >
    <ul class="container-px space-y-1 py-4">
      {
        nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              class:list={[
                'block rounded-lg px-3 py-3 text-base font-semibold hover:bg-stone-100',
                isActive(item.href) ? 'text-brand-700' : 'text-stone-800',
              ]}
            >
              {item.label}
            </a>
          </li>
        ))
      }
      <li class="grid grid-cols-2 gap-2 pt-3">
        <a href={site.phone.href} class="btn-secondary">
          <Icon name="phone" class="h-5 w-5 text-brand-700" /> Bellen
        </a>
        <a href="/contact/" class="btn-primary">Offerte</a>
      </li>
    </ul>
  </nav>
</header>

<script>
  // Toegankelijk mobiel menu: toggle + aria-expanded + Escape om te sluiten.
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  function setOpen(open: boolean) {
    if (!toggle || !menu || !iconOpen || !iconClose) return;
    menu.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Menu sluiten' : 'Menu openen');
    iconOpen.classList.toggle('hidden', open);
    iconClose.classList.toggle('hidden', !open);
  }

  const isOpen = () => toggle?.getAttribute('aria-expanded') === 'true';

  toggle?.addEventListener('click', () => setOpen(!isOpen()));

  // Sluit op Escape en geef focus terug aan de menuknop.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen()) {
      setOpen(false);
      toggle?.focus();
    }
  });

  // Sluit bij een klik buiten het menu en de knop.
  document.addEventListener('click', (e) => {
    if (!isOpen()) return;
    const target = e.target as Node;
    if (menu && toggle && !menu.contains(target) && !toggle.contains(target)) {
      setOpen(false);
    }
  });

  // Sluit bij het klikken van een link in het menu.
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
</script>
