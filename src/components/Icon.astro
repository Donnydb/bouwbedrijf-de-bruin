  quote:
    '<path d="M7 7h4v4c0 2.5-1.5 4-4 4.5V14c1.2-.4 2-1 2-2H7z" fill="currentColor" stroke="none"/><path d="M15 7h4v4c0 2.5-1.5 4-4 4.5V14c1.2-.4 2-1 2-2h-2z" fill="currentColor" stroke="none"/>',
  'chevron-down': '<path d="m6 9 6 6 6-6"/>',
