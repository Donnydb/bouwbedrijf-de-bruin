---
/**
 * Inline SVG-iconen (geen externe icon-font / requests).
 * Gebruik: <Icon name="phone" class="h-5 w-5 text-brand-600" />
 * Iconen erven `currentColor`. Decoratief tenzij `title` is meegegeven.
 */
interface Props {
  name: string;
  class?: string;
  title?: string;
  id?: string;
}
const { name, class: className = 'h-6 w-6', title, id } = Astro.props;

// 24x24 viewBox, stroke = currentColor, ronde uiteinden.
