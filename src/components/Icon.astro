  roof:
    '<path d="M2 12 12 4l10 8"/><path d="M19 9V5h-2v2"/><path d="M5 11v9h14v-9"/>',
  dormer:
    '<path d="M3 12 12 4l9 8"/><path d="M5 11v9h14v-9"/><path d="M9 20v-5h6v5"/><path d="M9 17h6"/>',
  roller:
    '<path d="M4 3h12a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"/><path d="M17 5h2a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2h-6a2 2 0 0 0-2 2v1"/><rect x="9" y="15" width="4" height="6" rx="1"/>',
  window:
    '<rect x="4" y="3" width="16" height="18" rx="1"/><path d="M4 12h16"/><path d="M12 3v18"/>',
  bolt:
    '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
};

const inner = icons[name] ?? '';
if (!inner && import.meta.env.DEV) {
  console.warn(`[Icon] Onbekend icoon: "${name}"`);
}
const ariaHidden = title ? undefined : 'true';
---
<svg
  id={id}
  class={className}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden={ariaHidden}
  role={title ? 'img' : undefined}
>
  {title && <title>{title}</title>}
  <Fragment set:html={inner} />
</svg>
