  ceiling:
    '<path d="M3 5h18"/><path d="M5 5l3 4"/><path d="M12 5v4"/><path d="M19 5l-3 4"/><path d="M4 13h16"/><path d="M4 17h16"/>',
  spray:
    '<path d="M9 8h6v12a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1z"/><path d="M9 8V5h4"/><path d="M17 4h.01M20 5h.01M18 7h.01M20 9h.01"/>',
